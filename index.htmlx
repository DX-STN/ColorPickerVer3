<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Color Picker 簡易版 ver3</title>
  <style>
    body {
      font-family: sans-serif;
      padding: 16px;
      font-size: 16px;
      background-color: #f5f5f5;
    }
    h1 {
      font-size: 20px;
      margin: 0 0 12px;
    }
    h2, h3 {
      font-size: 18px;
      margin: 16px 0 8px;
    }
    label {
      display: inline-block;
      margin: 4px 0;
    }
    input[type="file"],
    input[type="number"],
    button {
      font-size: 16px;
      padding: 6px 10px;
      box-sizing: border-box;
    }
    input[type="number"] {
      width: 80px;
    }
    #controls {
      margin-bottom: 12px;
    }
    #canvasWrapper {
      margin: 12px 0;
      text-align: center;
    }
    canvas {
      border: 1px solid #ccc;
      max-width: 100%;
      touch-action: none;
    }
    #info {
      margin: 8px 0;
      font-size: 14px;
      color: #333;
    }
    #rangeArea, #backupArea {
      margin-top: 16px;
      padding: 8px;
      background-color: #ffffff;
      border-radius: 4px;
      border: 1px solid #ddd;
    }
    #sizeInfo, #estimatedSizeInfo, #errorInfo, #backupInfo {
      margin-top: 4px;
      font-size: 13px;
      color: #555;
      white-space: pre-line;
    }
    #errorInfo {
      color: #c00;
    }
    #colorPreview {
      display: inline-block;
      width: 24px;
      height: 24px;
      border: 1px solid #000;
      vertical-align: middle;
      margin-left: 4px;
    }
  </style>
</head>
<body>
  <h1>Color Picker 簡易版 ver3</h1>

  <div id="controls">
    <label>
      画像を選択:
      <input type="file" id="imageInput" accept="image/*">
    </label>
  </div>

  <div id="canvasWrapper">
    <canvas id="canvas"></canvas>
  </div>

  <div id="info">
    画像を読み込んでから、キャンバスをタップするとその位置の色を取得します。
    <br>
    選択範囲の左上座標と縦横サイズを指定して、範囲内ピクセルをJSON形式でバックアップできます。
  </div>

  <div id="rangeArea">
    <h2>選択範囲の指定</h2>
    <div>
      <label>左上X:
        <input type="number" id="rangeX" value="0" min="0">
      </label>
      <label>左上Y:
        <input type="number" id="rangeY" value="0" min="0">
      </label>
    </div>
    <div>
      <label>幅(ピクセル):
        <input type="number" id="rangeW" value="100" min="1" max="512">
      </label>
      <label>高さ(ピクセル):
        <input type="number" id="rangeH" value="100" min="1" max="512">
      </label>
    </div>
    <button id="updateRangeBtn">この範囲でサイズ計算</button>
    <div id="sizeInfo"></div>
    <div id="estimatedSizeInfo"></div>
    <div id="errorInfo"></div>
  </div>

  <div id="backupArea">
    <h2>範囲内ピクセルのバックアップ</h2>
    <p style="margin:4px 0;">
      選択範囲内の各ピクセルの位置(x, y)と色(r, g, b)をJSON形式で保存します。
      <br>
      範囲は最大 512×512 ピクセルまで指定可能です。
    </p>
    <button id="backupBtn">選択範囲をJSONで保存</button>
    <div id="backupInfo"></div>
  </div>

  <script>
    const MAX_SIDE = 512;

    const imageInput = document.getElementById('imageInput');
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');

    const rangeXInput = document.getElementById('rangeX');
    const rangeYInput = document.getElementById('rangeY');
    const rangeWInput = document.getElementById('rangeW');
    const rangeHInput = document.getElementById('rangeH');
    const updateRangeBtn = document.getElementById('updateRangeBtn');

    const sizeInfo = document.getElementById('sizeInfo');
    const estimatedSizeInfo = document.getElementById('estimatedSizeInfo');
    const errorInfo = document.getElementById('errorInfo');

    const backupBtn = document.getElementById('backupBtn');
    const backupInfo = document.getElementById('backupInfo');

    let img = null;
    let imgWidth = 0;
    let imgHeight = 0;

    imageInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (ev) => {
        img = new Image();
        img.onload = () => {
          imgWidth = img.width;
          imgHeight = img.height;
          canvas.width = imgWidth;
          canvas.height = imgHeight;
          ctx.drawImage(img, 0, 0);
          errorInfo.textContent = '';
          sizeInfo.textContent =
            '画像サイズ: ' + imgWidth + ' × ' + imgHeight + ' ピクセル';
          updateRangeInfo();
        };
        img.onerror = () => {
          errorInfo.textContent = '画像の読み込みに失敗しました。別の画像を試してください。';
        };
        img.src = ev.target.result;
      };
      reader.readAsDataURL(file);
    });

    function clampRangeToImage(range) {
      if (!img) return range;
      const { x, y, w, h } = range;
      let nx = x;
      let ny = y;
      let nw = w;
      let nh = h;

      if (nx < 0) nx = 0;
      if (ny < 0) ny = 0;
      if (nx >= imgWidth) nx = imgWidth - 1;
      if (ny >= imgHeight) ny = imgHeight - 1;

      if (nx + nw > imgWidth) nw = imgWidth - nx;
      if (ny + nh > imgHeight) nh = imgHeight - ny;

      if (nw < 0) nw = 0;
      if (nh < 0) nh = 0;

      return { x: nx, y: ny, w: nw, h: nh };
    }

    function getCurrentRange() {
      const x = parseInt(rangeXInput.value, 10) || 0;
      const y = parseInt(rangeYInput.value, 10) || 0;
      let w = parseInt(rangeWInput.value, 10) || 0;
      let h = parseInt(rangeHInput.value, 10) || 0;

      if (w < 1) w = 1;
      if (h < 1) h = 1;
      if (w > MAX_SIDE) w = MAX_SIDE;
      if (h > MAX_SIDE) h = MAX_SIDE;

      return { x, y, w, h };
    }

    function setRangeInputs(range) {
      rangeXInput.value = range.x;
      rangeYInput.value = range.y;
      rangeWInput.value = range.w;
      rangeHInput.value = range.h;
    }

    function estimateJsonSize(range) {
      const { w, h } = range;
      const pixels = w * h;
      if (pixels <= 0) return 0;

      const base = '{"x":0,"y":0,"r":255,"g":255,"b":255},';
      const avgSizePerPixel = base.length;
      const approx = pixels * avgSizePerPixel + 2;
      return approx;
    }

    function toReadableSize(bytes) {
      if (bytes < 1024) return bytes + ' バイト';
      const kb = bytes / 1024;
      if (kb < 1024) return kb.toFixed(1) + ' KB';
      const mb = kb / 1024;
      return mb.toFixed(2) + ' MB';
    }

    function updateRangeInfo() {
      errorInfo.textContent = '';
      estimatedSizeInfo.textContent = '';

      if (!img) {
        sizeInfo.textContent = '画像を読み込んでから範囲を指定してください。';
        return;
      }

      let range = getCurrentRange();

      if (range.w > MAX_SIDE || range.h > MAX_SIDE) {
        errorInfo.textContent =
          '指定できる範囲は最大 ' + MAX_SIDE + ' × ' + MAX_SIDE + ' ピクセルまでです。';
        range.w = Math.min(range.w, MAX_SIDE);
        range.h = Math.min(range.h, MAX_SIDE);
      }

      range = clampRangeToImage(range);
      setRangeInputs(range);

      const pixels = range.w * range.h;
      sizeInfo.textContent =
        '選択範囲: 左上(' + range.x + ', ' + range.y + '), 幅 ' + range.w +
        ' × 高さ ' + range.h + ' ピクセル\n' +
        'ピクセル数: ' + pixels + ' 個';

      const approxBytes = estimateJsonSize(range);
      estimatedSizeInfo.textContent =
        '想定JSONサイズ(おおよそ): ' + toReadableSize(approxBytes) + '\n' +
        '※実際のサイズは色の値などにより前後します。';
    }

    updateRangeBtn.addEventListener('click', () => {
      updateRangeInfo();
    });

    ['change', 'input'].forEach(evt => {
      rangeXInput.addEventListener(evt, updateRangeInfo);
      rangeYInput.addEventListener(evt, updateRangeInfo);
      rangeWInput.addEventListener(evt, updateRangeInfo);
      rangeHInput.addEventListener(evt, updateRangeInfo);
    });

    backupBtn.addEventListener('click', () => {
      if (!img) {
        alert('先に画像を読み込んでください。');
        return;
      }

      updateRangeInfo();
      const msgErr = errorInfo.textContent.trim();
      if (msgErr) {
        alert(msgErr);
        return;
      }

      const range = getCurrentRange();
      const clamped = clampRangeToImage(range);

      if (clamped.w <= 0 || clamped.h <= 0) {
        alert('有効な選択範囲が指定されていません。');
        return;
      }

      const pixels = clamped.w * clamped.h;
      if (clamped.w > MAX_SIDE || clamped.h > MAX_SIDE) {
        alert('指定できる範囲は最大 ' + MAX_SIDE + ' × ' + MAX_SIDE + ' ピクセルまでです。');
        return;
      }

      const approxBytes = estimateJsonSize(clamped);
      const approxLabel = toReadableSize(approxBytes);

      const ok = confirm(
        '選択範囲内ピクセル数: ' + pixels + ' 個\n' +
        '想定JSONサイズ(おおよそ): ' + approxLabel + '\n\n' +
        'この範囲のピクセル(x, y, r, g, b)をJSON形式でバックアップファイルに保存します。\n' +
        '端末のストレージ状況によっては保存に時間がかかったり、失敗する可能性があります。\n\n' +
        'バックアップを保存しますか？'
      );
      if (!ok) return;

      try {
        const imageData = ctx.getImageData(clamped.x, clamped.y, clamped.w, clamped.h);
        const data = imageData.data;
        const w = clamped.w;
        const h = clamped.h;

        const pixelsArr = [];
        let index = 0;
        for (let yy = 0; yy < h; yy++) {
          for (let xx = 0; xx < w; xx++) {
            const r = data[index];
            const g = data[index + 1];
            const b = data[index + 2];
            pixelsArr.push({
              x: clamped.x + xx,
              y: clamped.y + yy,
              r,
              g,
              b
            });
            index += 4;
          }
        }

        const backupObj = {
          type: 'PixelColorBackup',
          createdAt: new Date().toISOString(),
          imageSize: { width: imgWidth, height: imgHeight },
          range: clamped,
          pixels: pixelsArr
        };

        const jsonText = JSON.stringify(backupObj);
        const blob = new Blob([jsonText], { type: 'application/json' });
        const sizeBytes = blob.size;
        const sizeLabel = toReadableSize(sizeBytes);

        const now = new Date();
        const now = new Date();
        const y = now.getFullYear();
        const m = String(now.getMonth() + 1).padStart(2, '0');
        const d = String(now.getDate()).padStart(2, '0');
        const hh = String(now.getHours()).padStart(2, '0');
        const mm = String(now.getMinutes()).padStart(2, '0');
        const fileName = 'PixelColorBackup_' + y + m + d + '-' + hh + mm + '.json';
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = fileName;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url) backupInfo.textContent = 'バックアップファイルを保存しました。\\n' + 'ファイル名: ' + fileName + '\\n' + '実際のJSONサイズ: ' + sizeLabel + '\\n' + '※端末やブラウザの設定により、保存場所はダウンロードフォルダなどになります。';
      } catch (e) {
        console.error(e);
        alert( 'バックアップの保存中にエラーが発生しました。\\n' + '端末のストレージ不足やメモリ不足などが原因の可能性があります。\\n\\n' + '以下の対処をお試しください。\\n' + '・ダウンロードフォルダなどの不要なファイルを削除して、ストレージの空きを増やす\\n' + '・選択範囲の縦横ピクセル数を小さくしてから、もう一度バックアップを実行する' );
      }
    });
    
    canvas.addEventListener('click', (e) => {
      if (!img) return;
      const rect = canvas.getBoundingClientRect();
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;
      const x = Math.floor((e.clientX - rect.left) * scaleX);
      const y = Math.floor((e.clientY - rect.top) * scaleY);
      const pixel = ctx.getImageData(x, y, 1, 1).data; const r = pixel[0];
      const g = pixel[1];
      const b = pixel[2];
      alert('座標(' + x + ', ' + y + ') の色\\n' + 'R: ' + r + ', G: ' + g + ', B: ' + b);
    });
  </script>
</body>
</html>
